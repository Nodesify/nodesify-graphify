{
  "name": "@nodesify/graphify",
  "version": "0.1.3",
  "description": "Turn any folder into a queryable knowledge graph",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nodesify-graphify": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "!dist/__tests__/**",
    "skills/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "napi:build": "napi build --platform --release dist",
    "napi:dev": "napi build --platform dist",
    "napi:artifacts": "napi artifacts",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "npx tsx src/__tests__/cli.test.ts"
  },
  "keywords": [
    "knowledge-graph",
    "code-analysis",
    "tree-sitter",
    "ast",
    "code-intelligence"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nodesify/nodesify-graphify.git"
  },
  "homepage": "https://github.com/nodesify/nodesify-graphify#readme",
  "bugs": {
    "url": "https://github.com/nodesify/nodesify-graphify/issues"
  },
  "dependencies": {
    "commander": "^12"
  },
  "devDependencies": {
    "tsx": "^4",
    "typescript": "^5",
    "@types/node": "^22",
    "@napi-rs/cli": "^2"
  },
  "engines": {
    "node": ">=20"
  },
  "napi": {
    "name": "graphify",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu"
      ]
    }
  },
  "optionalDependencies": {
    "@nodesify/graphify-win32-x64-msvc": "0.1.3",
    "@nodesify/graphify-darwin-x64": "0.1.3",
    "@nodesify/graphify-linux-x64-gnu": "0.1.3",
    "@nodesify/graphify-darwin-arm64": "0.1.3",
    "@nodesify/graphify-linux-arm64-gnu": "0.1.3"
  }
}
